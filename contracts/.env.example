# Copy to .env for Base Sepolia deploy. Never commit .env.
DEPLOYER_PRIVATE_KEY=0x

# Optional: automated testnet gas (no browser) via Coinbase Developer Platform
# One-time: https://portal.cdp.coinbase.com/access/api → API keys + wallet secret
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=
# CDP_WALLET_SECRET=

# Optional: custom RPC
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
